#!/bin/bash

# LaraKube Professional Builder (Standalone Edition)
# Compiles the CLI into standalone binaries with embedded PHP runtime

set -e

# ANSI escape codes for formatting
BOLD="\033[1m"
RESET="\033[0m"

# Ensure we are in the CLI directory
cd "$(dirname "$0")"

# Smart Argument Handling
NO_INSTALL=false
BUILD_TYPE="--local"
VERSION="local"

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --all) BUILD_TYPE="--all"; shift ;;
        --local) BUILD_TYPE="--local"; shift ;;
        --no-install) NO_INSTALL=true; shift ;;
        *) 
            # If it doesn't start with --, assume it's the version
            if [[ ! "$1" =~ ^-- ]]; then
                VERSION=$1
            fi
            shift 
            ;;
    esac
done

# Helper to run PHP via Docker
run_php() {
    export SHOW_WELCOME_MESSAGE=false
    
    # Load .env if it exists to pick up GITHUB_TOKEN
    if [ -f .env ]; then
        export $(grep -v '^#' .env | xargs)
    fi

    # Pass GITHUB_TOKEN to the ./php runner if it exists
    ENV_ARGS=""
    if [ ! -z "$GITHUB_TOKEN" ]; then
        ENV_ARGS="-e GITHUB_TOKEN=$GITHUB_TOKEN"
    fi

    ./php $ENV_ARGS -d phar.readonly=0 "$@"
}

build_phar() {
    echo -e "📦 Building PHAR foundation ${BOLD}[$VERSION]${RESET}..."
    run_php larakube app:build larakube --build-version=$VERSION
    run_php php -r "copy('builds/larakube', 'builds/larakube.phar');"
}

build_standalone() {
    PLATFORM=$1
    ARCH=$2
    echo "🏗 Packaging standalone binary for $PLATFORM ($ARCH)..."
    run_php ./vendor/bin/phpacker build $PLATFORM $ARCH --src=builds/larakube.phar --dest=builds/standalone -q
}

case $BUILD_TYPE in
    "--local")
        build_phar
        
        # Detect Local Arch
        OS=$(uname -s | tr '[:upper:]' '[:lower:]')
        [ "$OS" == "darwin" ] && OS="mac"
        
        ARCH=$(uname -m)
        [ "$ARCH" == "arm64" ] && ARCH="arm"
        [ "$ARCH" == "x86_64" ] && ARCH="x64"

        build_standalone $OS $ARCH
        
        if [ "$NO_INSTALL" = false ]; then
            echo "🚚 Installing local binary to /usr/local/bin/larakube (requires sudo)..."
            sudo mv builds/standalone/$OS/$OS-$ARCH /usr/local/bin/larakube
            sudo chmod +x /usr/local/bin/larakube
            echo -e "✅ LaraKube ${BOLD}[$VERSION]${RESET} is now live on your system!"
            echo "👉 Verify by running: larakube --version"
        else
            echo -e "✅ LaraKube ${BOLD}[$VERSION]${RESET} built successfully (skipped installation)."
            echo "👉 Run locally with: ./php builds/larakube.phar"
        fi
        ;;

    "--all")
        build_phar
        build_standalone linux x64
        build_standalone linux arm
        build_standalone mac x64
        build_standalone mac arm
        
        # Cleanup
        run_php php -r "unlink('builds/larakube.phar');"
        
        echo "✅ All standalone binaries built in builds/standalone/"
        ;;

    *)
        echo "Usage: ./build [--local | --all] [version]"
        exit 1
        ;;
esac
