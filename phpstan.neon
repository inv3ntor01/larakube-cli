includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    # Level 0 = the high-impact, fast, deterministic checks. The bug that crashed
    # init was an undefined CLASS (App\Traits\IngressController); undefined
    # functions (text()) are the same family — both still fail the gate below.
    level: 0
    paths:
        - app

    # Suppress KNOWN false-positive / best-practice CATEGORIES by identifier
    # (not a per-line baseline — so editing files never churns it):
    ignoreErrors:
        # Trait helper methods (e.g. $this->line()/info()) analyzed in the wrong
        # class context — the traits are always composed onto a Command at
        # runtime. Task #78 will replace this with targeted @mixin annotations to
        # restore method-level detection.
        - identifier: method.notFound
        # env() outside config — a Laravel best-practice nag, fine for this CLI.
        - identifier: larastan.noEnvCallsOutsideOfConfig
        # Command options added dynamically at runtime; PHPStan can't see them.
        - identifier: larastan.console.undefinedOption

    # NOTE: class.notFound and function.notFound are intentionally NOT ignored —
    # those are the undefined-symbol bugs we must catch. New code is checked
    # fresh; there is no baseline to maintain.
