includes:
    - vendor/larastan/larastan/extension.neon
    # Grandfathers the ~880 pre-existing legacy findings. You do NOT regenerate
    # this for new code — new code is checked normally and FAILS the gate if it
    # has a new undefined-symbol bug. Only regenerate if you deliberately fix
    # legacy findings or raise the level.
    - phpstan-baseline.neon

parameters:
    # Level 0 = the highest-impact, fastest, most deterministic checks:
    # undefined classes / methods / functions (exactly the unimported-enum bug
    # that crashed `init`, plus any others). Fast (seconds), light on memory,
    # and identical local vs CI. Raise the level later once we're confident —
    # the higher strict-rules levels are what caused the local/CI flakiness.
    level: 0
    paths:
        - app
    reportUnmatchedIgnoredErrors: false
