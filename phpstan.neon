includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    # Grandfathers the ~5750 pre-existing findings in this (AI-written) legacy
    # codebase at the strict bar, so the gate passes today but FAILS on any *new*
    # one. NEW and CHANGED code is held to the full strictness below; burn the
    # baseline down over time.
    - phpstan-baseline.neon

parameters:
    # "Very strict": max analysis level + phpstan-strict-rules (no loose ==,
    # required explicit types, no unsafe constructs, etc.). New code must pass
    # this bar — exactly the guardrail for AI-generated changes.
    level: max
    paths:
        - app

    # With a large legacy baseline, editing legacy files shifts error counts;
    # don't fail the build just because a baselined error no longer matches
    # (i.e. you happened to fix one). New, un-baselined errors still fail.
    reportUnmatchedIgnoredErrors: false
