#!/bin/bash

# LaraKube Composer Context-Aware Wrapper (Daemonized)
# Manages dependencies for the CURRENT project using the persistent PHP CLI daemon

# Ensure we use the local php script which manages the daemon
CLI_DIR=$(cd "$(dirname "$0")" && pwd)

# Run composer via the php runner
# We pass COMPOSER_ALLOW_SUPERUSER=1 because we run as root in the daemon
# then it maps back to host UID/GID if needed (but usually composer manages perms well)
"$CLI_DIR/php" composer "$@"
