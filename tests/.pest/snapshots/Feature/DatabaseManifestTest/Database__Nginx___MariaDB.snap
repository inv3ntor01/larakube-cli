              service:
                name: mariadb-companion
                port:
                  number: 80
  tls:
    - hosts:
        - mariadb-mariadb-test.dev.test


--- FILE: overlays/local/mariadb-companion.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mariadb-companion
spec:
  replicas: 1
  selector:
    matchLabels:
      app: mariadb-companion
  template:
    metadata:
      labels:
        app: mariadb-companion
    spec:
      containers:
        - name: companion
          image: phpmyadmin:latest
          ports:
            - containerPort: 80
          env:
            - name: PMA_HOST
              value: mariadb
            - name: PMA_USER
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_USERNAME
            - name: PMA_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: laravel-secrets
                  key: DB_PASSWORD
---
apiVersion: v1
kind: Service
metadata:
  name: mariadb-companion
spec:
  selector:
    app: mariadb-companion
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
  type: ClusterIP


