metadata:
  name: mariadb-test-laravel-storage-pv
  labels:
    larakube-project: mariadb-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate


