namespace: mariadb-test-production

resources:
  - app-volumes.yaml
  - mariadb-volumes.yaml
  - ../../base
  - namespace.yaml
  - config-patch.yaml

# Add production-specific patches here
patches:
  - path: ingress-patch.yaml
  - path: deployment-patch.yaml


