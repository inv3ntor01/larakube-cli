--- FILE: base/config.yaml ---
# Redundant - Assets moved to volumes.yaml and Runtime Config


--- FILE: base/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - mysql-deployment.yaml
  - laravel.yaml
  - volumes.yaml


--- FILE: base/laravel.yaml ---
---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      initContainers:
        - name: wait-for-deps
          image: mysql-test:latest
          imagePullPolicy: IfNotPresent
          command: ["sh", "-c", "until nc -z -v -w 1 mysql 3306; do echo 'Waiting for dependencies...'; sleep 2; done;"]
      containers:
        - name: php
          image: mysql-test:latest
          imagePullPolicy: IfNotPresent
          args: []
          ports:
            - containerPort: 8080
          env:
            - name: AUTORUN_ENABLED
              value: "true"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "true"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          livenessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 120
            periodSeconds: 60
            timeoutSeconds: 30
          readinessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 20
            timeoutSeconds: 30
          volumeMounts:
            - name: code
              mountPath: /var/www/html
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
      volumes:
        - name: code
          hostPath:
            path: /STABLE_TEST_PATH
            type: Directory
        - name: storage
          persistentVolumeClaim:
            claimName: mysql-test-laravel-storage-pvc

---

apiVersion: v1
kind: Service
metadata:
  name: web
spec:
  selector:
    app: web
  ports:
    - protocol: TCP
      port: 80
      targetPort: 8080
  type: ClusterIP

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/service.serversscheme: http
spec:
  rules:
    - host: mysql-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: web
                port:
                  number: 80
  tls:
    - hosts:
        - mysql-test.dev.test


--- FILE: base/mysql-deployment.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mysql
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: mysql
  template:
    metadata:
      labels:
        app: mysql
    spec:
      containers:
        - name: mysql
          image: mysql:8.4
          ports:
            - containerPort: 3306
          env:
            - name: MYSQL_DATABASE
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_DATABASE
            - name: MYSQL_USER
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_USERNAME
            - name: MYSQL_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: laravel-secrets
                  key: DB_PASSWORD
            - name: MYSQL_ROOT_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: laravel-secrets
                  key: DB_PASSWORD
          readinessProbe:
            tcpSocket:
              port: 3306
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            tcpSocket:
              port: 3306
            initialDelaySeconds: 15
            periodSeconds: 20
          volumeMounts:
            - name: db-data
              mountPath: /var/lib/mysql
      volumes:
        - name: db-data
          persistentVolumeClaim:
            claimName: mysql-test-mysql-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: mysql
spec:
  selector:
    app: mysql
  ports:
    - protocol: TCP
      port: 3306
      targetPort: 3306
  type: ClusterIP


--- FILE: base/volumes.yaml ---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: mysql-test-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: mysql-test-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi


--- FILE: overlays/local/config-patch.yaml ---
# Managed by LaraKube CLI (Runtime Injection)


--- FILE: overlays/local/infrastructure.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: mysql-test-local
  labels:
    larakube.io/project: mysql-test
    larakube.io/managed-by: larakube

---

apiVersion: v1
kind: PersistentVolume
metadata:
  name: mysql-test-laravel-storage-pv
  labels:
    larakube-project: mysql-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate


--- FILE: overlays/local/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: mysql-test-local

resources:
  - mysql-companion-ingress.yaml
  - mysql-companion.yaml
  - mysql-volumes.yaml
  - ../../base
  - infrastructure.yaml
  - config-patch.yaml

patches:
  - path: mysql-patch.yaml
  - path: patches.yaml


--- FILE: overlays/local/mysql-companion-ingress.yaml ---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: mysql-companion
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  rules:
    - host: mysql-mysql-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: mysql-companion
                port:
                  number: 80
  tls:
    - hosts:
        - mysql-mysql-test.dev.test


--- FILE: overlays/local/mysql-companion.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mysql-companion
spec:
  replicas: 1
  selector:
    matchLabels:
      app: mysql-companion
  template:
    metadata:
      labels:
        app: mysql-companion
    spec:
      containers:
        - name: companion
          image: phpmyadmin:latest
          ports:
            - containerPort: 80
          env:
            - name: PMA_HOST
              value: mysql
            - name: PMA_USER
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_USERNAME
            - name: PMA_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: laravel-secrets
                  key: DB_PASSWORD
---
apiVersion: v1
kind: Service
metadata:
  name: mysql-companion
spec:
  selector:
    app: mysql-companion
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
  type: ClusterIP


