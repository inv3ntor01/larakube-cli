--- FILE: base/config.yaml ---
# Redundant - Assets moved to volumes.yaml and Runtime Config


--- FILE: base/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - reverb-deployment.yaml
  - scheduler-cronjob.yaml
  - queues-deployment.yaml
  - laravel.yaml


--- FILE: base/laravel.yaml ---
---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      # The app runs as www-data; mounted PVCs (storage/, bootstrap/cache) come up
      # root-owned on real block storage (e.g. DOKS do-block-storage), so without
      # this they'd be read-only to the app. fsGroup makes the kubelet chown the
      # volume to this GID and add it to the container's supplementary groups, so
      # www-data can write. Harmless on k3s local-path (VPS), so it's identical
      # across VPS and managed clusters.
      securityContext:
        fsGroup: 33
      containers:
        - name: php
          image: kitchen-sink:latest
          imagePullPolicy: IfNotPresent
          args: []
          ports:
            - containerPort: 8080
          env:
            - name: AUTORUN_ENABLED
              value: "true"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "true"
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          livenessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 120
            periodSeconds: 60
            timeoutSeconds: 30
          readinessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 20
            timeoutSeconds: 30
          volumeMounts:
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: storage
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-data-pvc

---

apiVersion: v1
kind: Service
metadata:
  name: web
spec:
  selector:
    app: web
  ports:
    - protocol: TCP
      port: 80
      targetPort: 8080
  type: ClusterIP

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/service.serversscheme: http
spec:
  rules:
    - host: kitchen-sink.kube
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: web
                port:
                  number: 80
  tls:
    - hosts:
        - kitchen-sink.kube


--- FILE: base/queues-deployment.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: queues
spec:
  replicas: 1
  selector:
    matchLabels:
      app: queues
  template:
    metadata:
      labels:
        app: queues
    spec:
      # fsGroup so www-data can write the mounted PVC on block storage (DOKS etc.);
      # harmless on k3s local-path. See base/deployment.blade.php for the rationale.
      securityContext:
        fsGroup: 33
      initContainers:
        - name: wait-for-deps
          image: kitchen-sink:latest
          imagePullPolicy: IfNotPresent
          command: ["sh", "-c", "until curl -sf http://web/up; do echo 'Waiting for dependencies...'; sleep 2; done;"]
      containers:
        - name: php
          image: kitchen-sink:latest
          imagePullPolicy: IfNotPresent
          args: ["php", "artisan", "queue:work"]
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          env:
            - name: AUTORUN_ENABLED
              value: "false"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "false"
          volumeMounts:
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
          livenessProbe:
            exec:
              command: ["healthcheck-queue"]
            initialDelaySeconds: 30
            periodSeconds: 30
            timeoutSeconds: 10
          readinessProbe:
            exec:
              command: ["healthcheck-queue"]
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 10
      volumes:
        - name: storage
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-data-pvc


--- FILE: base/reverb-deployment.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: reverb
spec:
  replicas: 1
  selector:
    matchLabels:
      app: reverb
  template:
    metadata:
      labels:
        app: reverb
    spec:
      # fsGroup so www-data can write the mounted PVC on block storage (DOKS etc.);
      # harmless on k3s local-path. See base/deployment.blade.php for the rationale.
      securityContext:
        fsGroup: 33
      initContainers:
        - name: wait-for-deps
          image: kitchen-sink:latest
          imagePullPolicy: IfNotPresent
          command: ["sh", "-c", "until curl -sf http://web/up; do echo 'Waiting for dependencies...'; sleep 2; done;"]
      containers:
        - name: php
          image: kitchen-sink:latest
          imagePullPolicy: IfNotPresent
          args: ["php", "artisan", "reverb:start", "--host=0.0.0.0", "--port=8081"]
          ports:
            - containerPort: 8081
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          env:
            - name: AUTORUN_ENABLED
              value: "false"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "false"
          volumeMounts:
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
          livenessProbe:
            tcpSocket:
              port: 8081
            initialDelaySeconds: 30
            periodSeconds: 30
            timeoutSeconds: 10
          readinessProbe:
            tcpSocket:
              port: 8081
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 10
      volumes:
        - name: storage
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-storage-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: reverb
spec:
  selector:
    app: reverb
  ports:
    - protocol: TCP
      port: 8080
      targetPort: 8081
  type: ClusterIP


--- FILE: base/scheduler-cronjob.yaml ---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: scheduler
spec:
  schedule: "* * * * *"
  concurrencyPolicy: Replace
  jobTemplate:
    spec:
      template:
        spec:
          # fsGroup so www-data can write the mounted PVC on block storage (DOKS
          # etc.); harmless on k3s local-path. See base/deployment.blade.php.
          securityContext:
            fsGroup: 33
          initContainers:
            - name: wait-for-deps
              image: kitchen-sink:latest
              imagePullPolicy: IfNotPresent
              command: ["sh", "-c", "until curl -sf http://web/up; do echo 'Waiting for dependencies...'; sleep 2; done;"]
          containers:
            - name: php
              image: kitchen-sink:latest
              imagePullPolicy: IfNotPresent
              args: ["php", "artisan", "schedule:run"]
              resources:
                requests:
                  cpu: "50m"
                  memory: "128Mi"
                limits:
                  cpu: "1"
                  memory: "1Gi"
              envFrom:
                - configMapRef:
                    name: laravel-config
                - secretRef:
                    name: laravel-secrets
              env:
                - name: AUTORUN_ENABLED
                  value: "false"
                - name: AUTORUN_LARAVEL_MIGRATION
                  value: "false"
              volumeMounts:
                - name: storage
                  mountPath: /var/www/html/storage/logs
                  subPath: logs
                - name: storage
                  mountPath: /var/www/html/bootstrap/cache
                  subPath: bootstrap/cache
                - name: storage
                  mountPath: /var/www/html/storage/framework/sessions
                  subPath: framework/sessions
                - name: storage
                  mountPath: /var/www/html/storage/framework/views
                  subPath: framework/views
                - name: storage
                  mountPath: /var/www/html/storage/framework/cache
                  subPath: framework/cache
                - name: storage
                  mountPath: /var/www/html/storage/app/public
                  subPath: app/public
                - name: data
                  mountPath: /var/lib/larakube
          restartPolicy: OnFailure
          volumes:
            - name: storage
              persistentVolumeClaim:
                claimName: kitchen-sink-laravel-storage-pvc
            - name: data
              persistentVolumeClaim:
                claimName: kitchen-sink-laravel-data-pvc


--- FILE: overlays/local/app-volumes.yaml ---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: kitchen-sink-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: kitchen-sink-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi


--- FILE: overlays/local/config-patch.yaml ---
# Managed by LaraKube CLI (Runtime Injection)


--- FILE: overlays/local/infrastructure.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: kitchen-sink-local
  labels:
    larakube.io/project: kitchen-sink
    larakube.io/managed-by: larakube

---

apiVersion: v1
kind: PersistentVolume
metadata:
  name: kitchen-sink-laravel-storage-pv
  labels:
    larakube-project: kitchen-sink
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: kitchen-sink-laravel-data-pv
  labels:
    larakube-project: kitchen-sink
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/.infrastructure/volume_data"
    type: DirectoryOrCreate


--- FILE: overlays/local/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: kitchen-sink-local

resources:
  - app-volumes.yaml
  - ../../base
  - infrastructure.yaml
  - config-patch.yaml

patches:
  - path: patches.yaml

images:
  - name: kitchen-sink:latest
    newName: kitchen-sink
    newTag: local


--- FILE: overlays/local/patches.yaml ---
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          # Local dev: service connection vars (DB_*, REDIS_*, etc.) come from
          # ConfigMap/Secret via envFrom; everything else reads from .env
          # mounted on the hostPath. .env edits are live without larakube up.
          # Explicit env entries override Kubernetes service discovery auto-injection.
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          env:
            # Override Kubernetes auto-injected service discovery vars with ConfigMap values.
            # (Explicit env takes precedence over envFrom, which takes precedence over service links)
            - name: REDIS_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: REDIS_PORT
                  optional: true
            - name: DB_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_PORT
                  optional: true
            # Skip all SSU on-startup caching in local dev. Caching freezes
            # pod env vars (DB_CONNECTION=pgsql, etc.) into bootstrap/cache/*.php
            # files that win over process env, silently breaking test-time
            # overrides and hiding .env edits until pod restart. We disable:
            #   - the umbrella `optimize` command (older SSU images)
            #   - the granular individual cache commands (newer SSU images
            #     split optimize into separate steps; we cover both shapes)
            # Production keeps the defaults (true) for performance.
            - name: AUTORUN_LARAVEL_OPTIMIZE
              value: "false"
            - name: AUTORUN_LARAVEL_CONFIG_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_ROUTE_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_VIEW_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_EVENT_CACHE
              value: "false"
          volumeMounts:
            - name: code
              mountPath: /var/www/html
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: code
          hostPath:
            path: "/STABLE_TEST_PATH"
            type: Directory
        - name: storage
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: kitchen-sink-laravel-data-pvc
