  hostPath:
    path: /STABLE_TEST_PATH/.infrastructure/volume_data/meilisearch
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-meilisearch-pvc
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ""
  volumeName: meilisearch-test-meilisearch-pv
  resources:
    requests:
