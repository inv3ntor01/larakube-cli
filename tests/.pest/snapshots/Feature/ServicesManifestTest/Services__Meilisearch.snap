--- FILE: base/config.yaml ---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 1Gi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 1Gi

---

apiVersion: v1
kind: ConfigMap
metadata:
  name: laravel-config
data:
  APP_ENV: production
  APP_DEBUG: "false"
  APP_URL: "https://meilisearch-test.dev.test"
  ASSET_URL: "https://meilisearch-test.dev.test"
  DB_CONNECTION: "sqlite"
  DB_DATABASE: "/var/lib/larakube/database.sqlite"
  AUTORUN_LARAVEL_MIGRATION_SKIP_DB_CHECK: "true"
  CACHE_STORE: "database"
  SESSION_DRIVER: "database"
  SCOUT_DRIVER: "meilisearch"
  MEILISEARCH_HOST: "http://meilisearch:7700"
  MEILISEARCH_KEY: "larakubesecretpassword"


--- FILE: base/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - meilisearch-deployment.yaml
  - laravel.yaml
  - config.yaml


--- FILE: base/laravel.yaml ---
---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
        - name: php
          image: meilisearch-test:latest
          imagePullPolicy: IfNotPresent
          args: []
          ports:
            - containerPort: 8080
          env:
            - name: AUTORUN_ENABLED
              value: "true"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "true"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          livenessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 60
            periodSeconds: 30
            timeoutSeconds: 5
          readinessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5

          volumeMounts:
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: storage
          persistentVolumeClaim:
            claimName: meilisearch-test-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: meilisearch-test-laravel-data-pvc

---

apiVersion: v1
kind: Service
metadata:
  name: web
spec:
  selector:
    app: web
  ports:
    - protocol: TCP
      port: 80
      targetPort: 8080
  type: ClusterIP

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/service.serversscheme: http
spec:
  rules:
    - host: meilisearch-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: web
                port:
                  number: 80
  tls:
    - hosts:
        - meilisearch-test.dev.test


--- FILE: base/meilisearch-deployment.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: meilisearch
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: meilisearch
  template:
    metadata:
      labels:
        app: meilisearch
    spec:
      containers:
        - name: meilisearch
          image: getmeili/meilisearch:v1.12
          ports:
            - containerPort: 7700
          env:
            - name: MEILI_MASTER_KEY
              valueFrom:
                secretKeyRef:
                  name: laravel-secrets
                  key: MEILISEARCH_KEY
            - name: MEILI_ENV
              value: "production"
            - name: MEILI_DB_PATH
              value: "/meili_data"
          readinessProbe:
            httpGet:
              path: /health
              port: 7700
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 7700
            initialDelaySeconds: 15
            periodSeconds: 20
          volumeMounts:
            - name: meilisearch-data
              mountPath: /meili_data
      volumes:
        - name: meilisearch-data
          persistentVolumeClaim:
            claimName: meilisearch-test-meilisearch-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: meilisearch
spec:
  selector:
    app: meilisearch
  ports:
    - protocol: TCP
      port: 7700
      targetPort: 7700
  type: ClusterIP


--- FILE: overlays/local/infrastructure.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: meilisearch-test-local
  labels:
    larakube.io/project: meilisearch-test
    larakube.io/managed-by: larakube

---

apiVersion: v1
kind: PersistentVolume
metadata:
  name: meilisearch-test-laravel-storage-pv
  labels:
    larakube-project: meilisearch-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: meilisearch-test-laravel-data-pv
  labels:
    larakube-project: meilisearch-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/.infrastructure/volume_data"
    type: DirectoryOrCreate


--- FILE: overlays/local/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: meilisearch-test-local

resources:
  - meilisearch-ingress.yaml
  - meilisearch-volumes.yaml
  - ../../base
  - infrastructure.yaml

patches:
  - path: meilisearch-patch.yaml
  - path: patches.yaml


--- FILE: overlays/local/meilisearch-ingress.yaml ---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: meilisearch
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  rules:
    - host: meilisearch-meilisearch-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: meilisearch
                port:
                  number: 7700
  tls:
    - hosts:
        - meilisearch-meilisearch-test.dev.test


--- FILE: overlays/local/meilisearch-patch.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: meilisearch
spec:
  template:
    spec:
      containers:
        - name: meilisearch
          env:
            - name: MEILI_ENV
              value: "development"
            - name: MEILI_NO_ANALYTICS
              value: "true"


--- FILE: overlays/local/meilisearch-volumes.yaml ---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: meilisearch-test-meilisearch-pv
  labels:
    larakube-project: meilisearch-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /STABLE_TEST_PATH/.infrastructure/volume_data/meilisearch
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-meilisearch-pvc
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ""
  resources:
    requests:
      storage: 1Gi
  volumeName: meilisearch-test-meilisearch-pv


--- FILE: overlays/local/patches.yaml ---
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          volumeMounts:
            - name: code
              mountPath: /var/www/html
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: code
          hostPath:
            path: "/STABLE_TEST_PATH"
            type: Directory
        - name: storage
          persistentVolumeClaim:
            claimName: meilisearch-test-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: meilisearch-test-laravel-data-pvc

---

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteOnce
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: meilisearch-test-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteOnce

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    cert-manager.io/cluster-issuer: null
spec:
  tls:
    - hosts:
        - meilisearch-test.dev.test


--- FILE: overlays/production/deployment-patch.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 2
  template:
    spec:
      imagePullSecrets:
        - name: ghcr-creds


--- FILE: overlays/production/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: meilisearch-test-production

resources:
  - ../../base
  - namespace.yaml

# Add production-specific patches here
patches:
  - path: deployment-patch.yaml


--- FILE: overlays/production/namespace.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: meilisearch-test-production


