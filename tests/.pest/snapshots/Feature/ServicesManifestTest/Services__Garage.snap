--- FILE: overlays/local/garage-volumes.yaml ---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: garage-test-garage-pv
  labels:
    larakube-project: garage-test
spec:
  capacity:
    storage: 5Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /STABLE_TEST_PATH/.infrastructure/volume_data/garage
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: garage-test-garage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ""
  volumeName: garage-test-garage-pv
  resources:
    requests:
      storage: 5Gi


--- FILE: overlays/local/infrastructure.yaml ---
