--- FILE: overlays/production/deployment-patch.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
      imagePullSecrets:
        - name: ghcr-login

      initContainers:
        - name: wait-for-deps
          image: garage-test:latest

          command: ["sh", "-c", "true"]


