        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: garage
                port:
                  number: 3900
    - host: s3-web.garage-test.kube
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: garage
                port:
                  number: 3902
  tls:
    - hosts:
        - s3.garage-test.kube
        - s3-web.garage-test.kube


--- FILE: overlays/local/garage-volumes.yaml ---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: garage-test-garage-pv
  labels:
    larakube-project: garage-test
spec:
  capacity:
    storage: 5Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /STABLE_TEST_PATH/.infrastructure/volume_data/garage
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: garage-test-garage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ""
  volumeName: garage-test-garage-pv
  resources:
    requests:
      storage: 5Gi


--- FILE: overlays/local/infrastructure.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: garage-test-local
  labels:
    larakube.io/project: garage-test
    larakube.io/managed-by: larakube

---

apiVersion: v1
kind: PersistentVolume
metadata:
  name: garage-test-laravel-storage-pv
  labels:
    larakube-project: garage-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: garage-test-laravel-data-pv
  labels:
    larakube-project: garage-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/.infrastructure/volume_data"
    type: DirectoryOrCreate


--- FILE: overlays/local/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: garage-test-local

resources:
  - app-volumes.yaml
  - garage-ingress.yaml
  - garage-volumes.yaml
  - ../../base
  - infrastructure.yaml
  - config-patch.yaml

patches:
  - path: patches.yaml

images:
  - name: garage-test:latest
    newName: garage-test
    newTag: local


--- FILE: overlays/local/patches.yaml ---
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          # Local dev: service connection vars (DB_*, REDIS_*, etc.) come from
          # ConfigMap/Secret via envFrom; everything else reads from .env
          # mounted on the hostPath. .env edits are live without larakube up.
          # Explicit env entries override Kubernetes service discovery auto-injection.
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          env:
            # Override Kubernetes auto-injected service discovery vars with ConfigMap values.
            # (Explicit env takes precedence over envFrom, which takes precedence over service links)
            - name: REDIS_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: REDIS_PORT
                  optional: true
            - name: DB_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_PORT
                  optional: true
            # Skip all SSU on-startup caching in local dev. Caching freezes
            # pod env vars (DB_CONNECTION=pgsql, etc.) into bootstrap/cache/*.php
            # files that win over process env, silently breaking test-time
            # overrides and hiding .env edits until pod restart. We disable:
            #   - the umbrella `optimize` command (older SSU images)
            #   - the granular individual cache commands (newer SSU images
            #     split optimize into separate steps; we cover both shapes)
            # Production keeps the defaults (true) for performance.
            - name: AUTORUN_LARAVEL_OPTIMIZE
              value: "false"
            - name: AUTORUN_LARAVEL_CONFIG_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_ROUTE_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_VIEW_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_EVENT_CACHE
              value: "false"
          volumeMounts:
            - name: code
              mountPath: /var/www/html
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: code
          hostPath:
            path: "/STABLE_TEST_PATH"
            type: Directory
        - name: storage
          persistentVolumeClaim:
            claimName: garage-test-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: garage-test-laravel-data-pvc

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    cert-manager.io/cluster-issuer: null
spec:
  tls:
    - hosts:
        - garage-test.kube


