kind: PersistentVolumeClaim
metadata:
  name: livewire-test-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: livewire-test-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi


--- FILE: overlays/production/config-patch.yaml ---
# Managed by LaraKube CLI (Runtime Injection)


--- FILE: overlays/production/deployment-patch.yaml ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
      imagePullSecrets:
        - name: ghcr-login

      initContainers:
        - name: wait-for-deps
          image: livewire-test:latest

          command: ["sh", "-c", "true"]


--- FILE: overlays/production/ingress-patch.yaml ---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/router.tls.certresolver: letsencrypt
spec:
  rules:
    - host: livewire-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: web
                port:
                  number: 80
  tls:
    - hosts:
        - livewire-test.dev.test
      secretName: livewire-test-tls


--- FILE: overlays/production/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: livewire-test-production

resources:
  - app-volumes.yaml
  - ../../base
  - namespace.yaml
  - config-patch.yaml

# Add production-specific patches here
patches:
  - path: ingress-patch.yaml
  - path: deployment-patch.yaml

images:
  - name: livewire-test:latest
    newName: livewire-test
    newTag: production-latest


--- FILE: overlays/production/namespace.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: livewire-test-production


