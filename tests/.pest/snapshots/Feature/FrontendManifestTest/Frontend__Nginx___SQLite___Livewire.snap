--- FILE: base/config.yaml ---
# Redundant - Assets moved to volumes.yaml and Runtime Config


--- FILE: base/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - laravel.yaml


--- FILE: base/laravel.yaml ---
---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      # The app runs as www-data; mounted PVCs (storage/, bootstrap/cache) come up
      # root-owned on real block storage (e.g. DOKS do-block-storage), so without
      # this they'd be read-only to the app. fsGroup makes the kubelet chown the
      # volume to this GID and add it to the container's supplementary groups, so
      # www-data can write. Harmless on k3s local-path (VPS), so it's identical
      # across VPS and managed clusters.
      securityContext:
        fsGroup: 33
      containers:
        - name: php
          image: livewire-test:latest
          imagePullPolicy: IfNotPresent
          args: []
          ports:
            - containerPort: 8080
          env:
            - name: AUTORUN_ENABLED
              value: "true"
            - name: AUTORUN_LARAVEL_MIGRATION
              value: "true"
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "1"
              memory: "1Gi"
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          livenessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 120
            periodSeconds: 60
            timeoutSeconds: 30
          readinessProbe:
            httpGet:
              path: /up
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 20
            timeoutSeconds: 30
          volumeMounts:
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: storage
          persistentVolumeClaim:
            claimName: livewire-test-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: livewire-test-laravel-data-pvc

---

apiVersion: v1
kind: Service
metadata:
  name: web
spec:
  selector:
    app: web
  ports:
    - protocol: TCP
      port: 80
      targetPort: 8080
  type: ClusterIP

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/service.serversscheme: http
spec:
  rules:
    - host: livewire-test.dev.test
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: web
                port:
                  number: 80
  tls:
    - hosts:
        - livewire-test.dev.test


--- FILE: overlays/local/app-volumes.yaml ---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: livewire-test-laravel-storage-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: livewire-test-laravel-data-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi


--- FILE: overlays/local/config-patch.yaml ---
# Managed by LaraKube CLI (Runtime Injection)


--- FILE: overlays/local/infrastructure.yaml ---
apiVersion: v1
kind: Namespace
metadata:
  name: livewire-test-local
  labels:
    larakube.io/project: livewire-test
    larakube.io/managed-by: larakube

---

apiVersion: v1
kind: PersistentVolume
metadata:
  name: livewire-test-laravel-storage-pv
  labels:
    larakube-project: livewire-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/storage"
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: livewire-test-laravel-data-pv
  labels:
    larakube-project: livewire-test
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: "/STABLE_TEST_PATH/.infrastructure/volume_data"
    type: DirectoryOrCreate


--- FILE: overlays/local/kustomization.yaml ---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: livewire-test-local

resources:
  - app-volumes.yaml
  - ../../base
  - infrastructure.yaml
  - config-patch.yaml

patches:
  - path: patches.yaml

images:
  - name: livewire-test:latest
    newName: livewire-test
    newTag: local


--- FILE: overlays/local/patches.yaml ---
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  template:
    spec:
      containers:
        - name: php
          imagePullPolicy: IfNotPresent
          # Local dev: service connection vars (DB_*, REDIS_*, etc.) come from
          # ConfigMap/Secret via envFrom; everything else reads from .env
          # mounted on the hostPath. .env edits are live without larakube up.
          # Explicit env entries override Kubernetes service discovery auto-injection.
          envFrom:
            - configMapRef:
                name: laravel-config
            - secretRef:
                name: laravel-secrets
          env:
            # Override Kubernetes auto-injected service discovery vars with ConfigMap values.
            # (Explicit env takes precedence over envFrom, which takes precedence over service links)
            - name: REDIS_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: REDIS_PORT
                  optional: true
            - name: DB_PORT
              valueFrom:
                configMapKeyRef:
                  name: laravel-config
                  key: DB_PORT
                  optional: true
            # Skip all SSU on-startup caching in local dev. Caching freezes
            # pod env vars (DB_CONNECTION=pgsql, etc.) into bootstrap/cache/*.php
            # files that win over process env, silently breaking test-time
            # overrides and hiding .env edits until pod restart. We disable:
            #   - the umbrella `optimize` command (older SSU images)
            #   - the granular individual cache commands (newer SSU images
            #     split optimize into separate steps; we cover both shapes)
            # Production keeps the defaults (true) for performance.
            - name: AUTORUN_LARAVEL_OPTIMIZE
              value: "false"
            - name: AUTORUN_LARAVEL_CONFIG_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_ROUTE_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_VIEW_CACHE
              value: "false"
            - name: AUTORUN_LARAVEL_EVENT_CACHE
              value: "false"
          volumeMounts:
            - name: code
              mountPath: /var/www/html
            - name: storage
              mountPath: /var/www/html/storage/logs
              subPath: logs
            - name: storage
              mountPath: /var/www/html/bootstrap/cache
              subPath: bootstrap/cache
            - name: storage
              mountPath: /var/www/html/storage/framework/sessions
              subPath: framework/sessions
            - name: storage
              mountPath: /var/www/html/storage/framework/views
              subPath: framework/views
            - name: storage
              mountPath: /var/www/html/storage/framework/cache
              subPath: framework/cache
            - name: storage
              mountPath: /var/www/html/storage/app/public
              subPath: app/public
            - name: data
              mountPath: /var/lib/larakube
      volumes:
        - name: code
          hostPath:
            path: "/STABLE_TEST_PATH"
            type: Directory
        - name: storage
          persistentVolumeClaim:
            claimName: livewire-test-laravel-storage-pvc
        - name: data
          persistentVolumeClaim:
            claimName: livewire-test-laravel-data-pvc

---

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web
  annotations:
    cert-manager.io/cluster-issuer: null
spec:
  tls:
    - hosts:
        - livewire-test.dev.test


